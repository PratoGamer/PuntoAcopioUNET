@page "/"
@using PuntoAcopioUNET.Services
@inject LogisticaService LogisticaService

<div class="container-fluid py-4 bg-light min-vh-100">
    <!-- Encabezado Principal -->
    <div class="row mb-4">
        <div class="col-12 text-center text-md-start">
            <h1 class="display-6 fw-bold text-dark mb-1">Punto de Acopio UNET</h1>
            <p class="text-muted">Calculador de Costos Logísticos Optimizados (Algoritmo Recursivo con Poda Asíncrona)
            </p>
        </div>
    </div>

    <div class="row g-4">
        <!-- Panel Izquierdo: Entrada de Datos -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100 rounded-4">
                <div class="card-body p-4">
                    <h5 class="card-title fw-bold mb-3 text-secondary">
                        <i class="bi bi-gear-fill me-2 text-primary"></i>Configuración de Secuencia
                    </h5>

                    <!-- Entrada de números -->
                    <div class="mb-4">
                        <label class="form-label text-muted small fw-bold">Ingresar Número Entero (Solo
                            positivos)</label>
                            <div class="input-group">
                                <input type="number" min="0" @bind="nuevoNumero" @bind:event="oninput"
                                       @onkeyup="HandleKeyUp" class="form-control border-end-0 py-2 rounded-start-3"
                                       placeholder="Ej. 15" />
                                <button class="btn btn-primary px-4 rounded-end-3" type="button" @onclick="AgregarNumero"
                                        disabled="@(nuevoNumero < 0)">
                                    <i class="bi bi-plus me-1"></i> Añadir
                                </button>
                            </div>
                            @if (nuevoNumero < 0)
                            {
                                <span class="text-danger small mt-1 d-block"><i class="bi bi-exclamation-circle-fill me-1"></i>
                                    No se permiten números negativos.</span>
                                }
                            </div>

                            <!-- Presets de Prueba Rápida -->
                            <div class="mb-4">
                                <label class="form-label text-muted small fw-bold">Pruebas Rápidas (Presets)</label>
                                <div class="d-flex gap-2 flex-wrap">
                                    <button class="btn btn-sm btn-outline-secondary rounded-pill"
                                            @onclick="() => CargarPreset(new int[] { 10, 5, 20 })">Caso Simple</button>
                                    <button class="btn btn-sm btn-outline-secondary rounded-pill"
                                            @onclick="() => CargarPreset(new int[] { 4, 8, 3, 12 })">Caso Mediano</button>
                                    <button class="btn btn-sm btn-outline-secondary rounded-pill"
                                            @onclick="() => CargarPreset(new int[] { 3, 6, 12, 2, 4 })">Caso Complejo</button>
                                </div>
                            </div>

                            <hr class="text-muted my-3" />

                            <!-- Secuencia Original -->
                            <div class="mb-4">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <label class="form-label text-muted small fw-bold mb-0">Secuencia Original</label>
                                    @if (LogisticaService.secuenciaOriginal.Any())
                                    {
                                        <button class="btn btn-sm text-danger p-0 border-0 bg-transparent" @onclick="LimpiarTodo">
                                            <i class="bi bi-trash-fill me-1"></i>Limpiar Todo
                                        </button>
                                    }
                                </div>

                                @if (!LogisticaService.secuenciaOriginal.Any())
                                {
                                    <div class="text-center py-4 bg-light rounded-3 text-muted border border-dark border-2">
                                        <i class="bi bi-list-ol d-block fs-3 mb-2 opacity-50"></i>
                                        <span class="small">La secuencia está vacía. Añade números para comenzar.</span>
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex flex-wrap gap-2 p-3 bg-light rounded-3 border">
                                        @for (int i = 0; i < LogisticaService.secuenciaOriginal.Count; i++)
                                        {
                                            int index = i;
                                            <span
                                                class="badge bg-dark fs-6 py-2 px-3 rounded-pill d-inline-flex align-items-center gap-2 shadow-sm ">
                                                @LogisticaService.secuenciaOriginal[index]
                                                <i class="bi bi-x text-danger opacity-75 opacity-100-hover " role="button"
                                                   @onclick="() => EliminarNumero(index)"></i>
                                            </span>
                                        }
                                    </div>
                                }
                            </div>

                            <!-- Acción de Cálculo -->
                            <button class="btn btn-success w-100 py-3 rounded-3 fw-bold fs-5 shadow-sm text-white"
                                    @onclick="ProcesarCalculo"
                                    disabled="@(isCalculating || !LogisticaService.secuenciaOriginal.Any()|| string.IsNullOrWhiteSpace(destino))">
                                @if (isCalculating)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>Procesando Árbol...</span>
                                }
                                else
                                {
                                    <span><i class="bi bi-lightning-charge-fill me-2"></i>Calcular Logística</span>
                                }
                            </button>
                                <label class="form-label fw-bold text-muted">
        Destino del Cargamento
    </label>

    <input class="form-control"
           @bind="destino"
           placeholder="Ej. Mérida, San Cristóbal..." />
                        </div>

                    </div>
                </div>

                <!-- Panel Derecho: Resultados -->
                <div class="col-lg-8">
                    <div class="card border-0 shadow-sm h-100 rounded-4">
                        <div class="card-body p-4">
                            <h5 class="card-title fw-bold mb-4 text-secondary">
                                <i class="bi bi-bar-chart-line-fill me-2 text-success"></i>Resultados del Análisis de Costos
                            </h5>

                            @if (!haCalculado && !isCalculating)
                            {
                                <div class="text-center py-5 my-5 text-muted">
                                    <img src="https://placehold.co/150x150/e9ecef/6c757d?text=Logistica"
                                         class="mb-4 rounded-circle border p-2" alt="Logo Logística" />
                                    <h4>Listo para Calcular</h4>
                                    <p class="text-muted col-10 col-md-8 mx-auto">Configura tu secuencia original en el panel de la
                                        izquierda y haz clic en "Calcular Logística" para ver la magia de la optimización recursiva.
                                    </p>
                                </div>
                            }
                            else if (isCalculating)
                            {
                                <div class="text-center py-5 my-5">
                                    <div class="spinner-grow text-success" role="status">
                                        <span class="visually-hidden">Calculando...</span>
                                    </div>
                                    <h4 class="mt-4 fw-bold">Procesando Hilos en Segundo Plano</h4>
                                    <p class="text-muted col-10 col-md-8 mx-auto">Ejecutando tres algoritmos asíncronos recursivos
                                        en paralelo, aplicando poda extrema de ramas de costo mayor a 60.</p>
                                    </div>
                                }
                    else
                                {
                                    <!-- Grid de 3 Columnas para los Resultados -->
                    <div class="row g-4">

    <div class="col-lg-4 col-md-6">
       
        @RenderCardResultados(
            "Mínimo Ascendente",
            "bi-graph-up-arrow",
            "bg-primary-subtle text-primary border-top border-4 border-primary",
            LogisticaService.ResultadoAscendente)
    </div>

    <div class="col-lg-4 col-md-6">
        @RenderCardResultados(
            "Mínimo Descendente",
            "bi-graph-down-arrow",
            "bg-info-subtle text-info-emphasis border-top border-4 border-info",
            LogisticaService.ResultadoDescendente)
    </div>

    <div class="col-lg-4 col-md-12">
        @RenderCardResultados(
            "Mínimo Constante",
            "bi-dash-circle-fill",
            "bg-warning-subtle text-warning-emphasis border-top border-4 border-warning",
            LogisticaService.ResultadoConstante)
    </div>

</div>
                                }
@if (cargamentos.Any())
{
    <h5 class="mt-4">Historial de Cargamentos</h5>

    @foreach (var item in cargamentos)
    {
        <div class="card mb-2 alert alert-success shadow-sm mt-3">
            <div class="card-body">
                <strong>Destino:</strong>  <span class="badge bg-success small"> @item.Destino</span> <br />
                <strong>Secuencia:</strong> <span class="badge bg-success small">@string.Join(" → ", item.Secuencia)</span>  <br />
            <strong>Método:</strong> <span class="badge bg-success small">@item.Metodo</span> <br />
                <strong>Costo:</strong> <span class="badge bg-success small"> @item.Costo pts</span>
            </div>
        </div>
    }
}
                            </div>
                        </div>
                    </div>
                </div>
            </div>

@code {
    private int nuevoNumero = 0;
    private bool isCalculating = false;
    private bool haCalculado = false;
    private List<(string Destino, List<int> Secuencia, string Metodo, int Costo)> cargamentos = new();
private string destino = "";
private void ObtenerMejorOpcion()
{
    var opciones = new List<(string Metodo, Datos Resultado)>
    {
        ("Ascendente", LogisticaService.ResultadoAscendente),
        ("Descendente", LogisticaService.ResultadoDescendente),
        ("Constante", LogisticaService.ResultadoConstante)
    };

    var mejor = opciones
        .Where(x => x.Resultado != null)
        .OrderBy(x => x.Resultado.Costos.Sum())
        .FirstOrDefault();

    if (mejor.Resultado != null)
    {
        mejorMetodo = mejor.Metodo;
        mejorCosto = mejor.Resultado.Costos.Sum();
    }
    else
    {
        mejorMetodo = "Sin solución";
        mejorCosto = 0;
    }
}

    // Agregar número a la secuencia
    private void AgregarNumero()
    {
        if (nuevoNumero >= 0)
        {
            LogisticaService.secuenciaOriginal.Add(nuevoNumero);
            nuevoNumero = 0;
        }
    }

    // Detectar Enter en la caja de texto
    private void HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AgregarNumero();
        }
    }

    // Cargar un preset de pruebas
    private void CargarPreset(int[] numeros)
    {
        LogisticaService.secuenciaOriginal = numeros.ToList();
        haCalculado = false;
    }

    // Eliminar número individual
    private void EliminarNumero(int index)
    {
        LogisticaService.secuenciaOriginal.RemoveAt(index);
        haCalculado = false;
    }

    // Vaciar lista
    private void LimpiarTodo()
    {
        LogisticaService.secuenciaOriginal.Clear();
        haCalculado = false;
    }

    // Invocar cálculo asíncrono
    private async Task ProcesarCalculo()
    {
        if (string.IsNullOrWhiteSpace(destino))
{
    return;
}
        if (!LogisticaService.secuenciaOriginal.Any()) return;

        isCalculating = true;
        haCalculado = false;
        StateHasChanged(); // Renderiza el Spinner inmediatamente

        // Pequeña pausa opcional (50ms) para garantizar que la UI pinte el Loading antes de la carga de CPU
        await Task.Delay(50);

        // Se ejecuta en hilos de fondo de manera fluida
        await LogisticaService.CalcularOrden();
ObtenerMejorOpcion();
cargamentos.Add((
    destino,
    LogisticaService.secuenciaOriginal.ToList(),
    mejorMetodo,
    mejorCosto
));
// Limpiar para un nuevo cargamento
destino = "";
LogisticaService.secuenciaOriginal.Clear();
nuevoNumero = 0;
        isCalculating = false;
        haCalculado = true;
    }
    private string mejorMetodo = "";
private int mejorCosto = 0;



    // Fragmento de Renderizado Reutilizable para las Tarjetas de Resultados
    private RenderFragment RenderCardResultados(string titulo, string icon, string colorClass, Datos resultado) => __builder
=>
    {
        <div class="card h-100 border-0 bg-white shadow-sm rounded-3 overflow-hidden">
            <div class="card-header @colorClass d-flex justify-content-between align-items-center py-3 border-0">
                <span class="fw-bold"><i class="bi @icon me-2"></i>@titulo</span>
            </div>
            <div class="card-body p-3">
                @if (resultado == null)
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-diagram-3-fill fs-4 d-block mb-2 opacity-50"></i>
                        <span class="small fw-semibold text-danger">Poda Excedida (> 60)</span>
                        <p class="small text-muted mt-1 mb-0">No se halló solución con costo menor al límite.</p>
                    </div>
                }
                else
                {
                    <!-- Costo Total Acumulado -->
                    <div class="text-center mb-3 bg-light rounded-3 py-2 border">
                        <span class="small text-muted d-block text-uppercase fw-bold ">Costo Total</span>
                        <span class="fs-4 fw-bold text-success">@resultado.Costos.Sum() ptos</span>
                    </div>

                    <!-- Secuencia Resultante -->
                    <div class="mb-3">
                        <span class="small text-muted fw-bold d-block mb-1"><i class="bi bi-diagram-3 me-2"></i>Secuencia Final:</span>
                        <div class="d-flex flex-wrap gap-1">
                            @foreach (var val in resultado.Secuencia)
                            {
                                <span class="badge bg-secondary p-1 px-2 rounded">@val</span>
                            }
                        </div>
                    </div>

                    <!-- Lista de Operaciones -->
                    <div>
                        <span class="small text-muted fw-bold d-block mb-2"><i class="bi bi-list-check me-2"></i>Pasos Ejecutados:</span>
                        <div class="timeline-visual">
                            @for (int i = 0; i < resultado.Operaciones.Count; i++)
                            {
                                var op = resultado.Operaciones[i];
                                var costoOp = resultado.Costos[i];
                                <div
                                    class="step-row d-flex align-items-center justify-content-between mb-2 p-2 rounded bg-light border-start border-3 border-success">
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="orig-val text-muted small">@op.valorAntes</span>
                                        <span class="badge bg-dark font-monospace small">@op.operacion</span>
                                        <i class=" bi bi-arrow-right text-muted small"></i>
                                        <span class="dest-val fw-bold text-dark">@op.valorDespues</span>
                                    </div>
                                    <span class="badge border border-secondary text-secondary small">+$@costoOp</span>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    };
}

