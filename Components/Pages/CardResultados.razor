<!-- Modulo de Tarjeta de Resultados -->
@using PuntoAcopioUNET.Services

<div class="card h-100 border-0 bg-white shadow-sm rounded-3 overflow-hidden" style="opacity: @(Resultado == null ? "0.6" : "1.0")">

    <!-- Cabecera de la tarjeta -->
    <div class="card-header @ColorCabecera d-flex justify-content-between align-items-center py-2 border-0 small">
        <span class="fw-bold"><i class="bi @Icono me-1"></i>@Titulo</span>
    </div>

    <!-- Cuerpo de la tarjeta -->
    <div class="card-body p-3">
        @if (Resultado == null)
        {
            <div class="text-center py-3 text-muted">
                <i class="bi bi-diagram-3-fill fs-5 d-block mb-1 opacity-50"></i>
                <span class="small fw-semibold text-danger">Poda Excedida (No Viable)</span>
            </div>
        }
        else
        {
            <!-- Caja del Costo Total -->
            <div class="text-center mb-2 bg-light rounded-3 py-2 border">
                <span class="small text-muted d-block text-uppercase fw-bold" style="font-size: 0.75rem;">Costo</span>
                <span class="fs-5 fw-bold text-success">@Resultado.Costos.Sum() pts</span>
            </div>

            <!-- Secuencia de salida -->
            <div class="mb-2">
                <span class="text-muted fw-bold d-block mb-1 small"><i class="bi bi-diagram-3 me-1"></i>Salida:</span>
                <div class="d-flex flex-wrap gap-1">
                    @foreach (var val in Resultado.Secuencia)
                    {
                        <span class="badge bg-secondary p-1 px-2 rounded small">@val</span>
                    }
                </div>
            </div>

            <!-- Lista de Operaciones / Cálculos -->
            <div>
                <span class="text-muted fw-bold d-block mb-1 small"><i class="bi bi-list-check me-1"></i>Cálculos:</span>
                <div class="vh-25 overflow-y-auto border rounded p-2 bg-light" style="max-height: 150px;">
                    @for (int i = 0; i < Resultado.Operaciones.Count; i++)
                    {
                        var op = Resultado.Operaciones[i];
                        var costoOp = Resultado.Costos[i];

                        <div class="d-flex align-items-center mb-1 p-1 rounded bg-white border-start border-3 border-success small" style="font-size: 0.8rem;">
                            <span class="text-muted">@op.valorAntes</span>
                            <span class="badge bg-dark mx-1 font-monospace" style="font-size: 0.7rem;">@op.operacion</span>
                            <i class="bi bi-arrow-right text-muted mx-1"></i>
                            <span class="fw-bold text-dark">@op.valorDespues</span>
                            <span class="text-secondary ms-1">(+@costoOp)</span>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {

	// Parametros de Entrada para la Tarjeta de Resultados
    [Parameter] public string Titulo { get; set; } = string.Empty;
    [Parameter] public string Icono { get; set; } = string.Empty;
    [Parameter] public string ColorCabecera { get; set; } = string.Empty;
    [Parameter] public Datos? Resultado { get; set; } 

}